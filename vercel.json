{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "env": [
    {
      "key": "VITE_SUPABASE_URL",
      "target": "production",
      "type": "encrypted"
    },
    {
      "key": "VITE_SUPABASE_ANON_KEY",
      "target": "production",
      "type": "encrypted"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
